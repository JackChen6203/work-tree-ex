# Local development overrides for `docker compose --profile dev`.
# Copy to `.env.local` and adjust as needed.

APP_ENV=dev
TRIPS_STORE=postgres
RUNTIME_MODE=single

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_HOST=postgres
DB_PORT=5432
DB_USER=travel
DB_PASSWORD=travel
DB_NAME=travel_planner
DB_SSLMODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=redispass
REDIS_DB=0

JWT_SECRET=change-me-in-local-dev
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_HOURS=168

WORKER_HTTP_PORT=8091
