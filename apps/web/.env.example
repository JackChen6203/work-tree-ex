# Vite only reads env files inside apps/web.
# Copy this file to apps/web/.env.local when you run the frontend with `npm run dev`.

# Leave unset when you serve the frontend behind nginx on the same origin.
VITE_API_BASE_URL=http://localhost:8080
VITE_ENABLE_MAGIC_LINK_AUTH=true
VITE_OAUTH_PROVIDERS=google
VITE_MAPBOX_ACCESS_TOKEN=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
