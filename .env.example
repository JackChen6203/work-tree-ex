# Root .env is used by docker compose and is also the exact file body
# uploaded to the GitHub Actions secret APP_ENV_FILE for deployment.

# ── Application ─────────────────────────────────────────────
APP_ENV=dev
TRIPS_STORE=postgres
# Runtime topology mode:
# - single: single-host first (distributed Redis features disabled)
# - distributed: enable Redis-backed distributed features
RUNTIME_MODE=single
# API startup migrations default to true outside APP_ENV=prod and false in prod.
# Production deploys should run migrations through the deployment migration job.
AUTO_RUN_MIGRATIONS=

# ── HTTP Server / CORS ──────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=15
HTTP_SHUTDOWN_TIMEOUT_SEC=10
FRONTEND_BASE_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# ── PostgreSQL / Docker Compose ─────────────────────────────
POSTGRES_IMAGE=imresamu/postgis:16-3.4.4-alpine3.21
# Local Docker Postgres example:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=travel
# DB_PASSWORD=change-this-db-password
# DB_NAME=travel_planner
# DB_SSLMODE=disable
#
# Supabase pooler example:
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-db-password
DB_NAME=postgres
DB_SSLMODE=require
DB_APP_ROLE=service_role
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# Use a full URL for migrations when the password may contain special chars.
# Example:
# MIGRATE_DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_URLENCODED_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
MIGRATE_DATABASE_URL=

# Optional Supabase keys (only needed when integrating Supabase HTTP clients).
# Backend-only secret, never expose to frontend bundle.
SUPABASE_SERVICE_ROLE_KEY=
# Frontend public key, can be exposed to browser runtime.
SUPABASE_ANON_KEY=

# ── Redis / Docker Compose ──────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_CONN_MAX_LIFETIME_MIN=30
REDIS_CONN_MAX_IDLE_MIN=5

# ── JWT / Session ───────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_HOURS=168
AUTH_ALLOW_MAGIC_LINK_PREVIEW=false

# ── LLM Provider Encryption ─────────────────────────────────
# AES-256-GCM key used to decrypt llm_provider_configs.encrypted_key
# Accepts either:
# - 32-byte raw string
# - base64-encoded 32-byte key
LLM_ENCRYPTION_KEY=replace-with-32-byte-key-or-base64

# ── Optional OAuth Client IDs ───────────────────────────────
# Google production login requires both client ID and client secret.
# Preview-code magic link is development-only.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_X_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_LINE_CLIENT_ID=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_WECHAT_CLIENT_ID=
OAUTH_TRIPADVISOR_CLIENT_ID=
OAUTH_BOOKING_CLIENT_ID=

# ── Map Provider (BE-P2-05) ────────────────────────────────
MAP_PRIMARY_PROVIDER=google
MAP_DAILY_QUOTA=10000
MAP_RPS_LIMIT=20
GOOGLE_MAPS_API_KEY=
MAPBOX_API_KEY=

# ── FCM Push (BE-P2-06) ────────────────────────────────────
# Priority:
# 1) Firebase Admin SDK (service account)
# 2) Legacy FCM HTTP server key
# 3) noop (disabled push)
FCM_SERVICE_ACCOUNT_FILE=
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
FCM_SERVER_KEY=
FCM_SEND_ENDPOINT=https://fcm.googleapis.com/fcm/send
FIREBASE_SHADOW_ENABLED=false
FIREBASE_DATABASE_URL=
FIREBASE_SHADOW_PATH_PREFIX=shadow

# ── Email Provider (BE-P2-07) ──────────────────────────────
EMAIL_PROVIDER_PRIMARY=noop
EMAIL_PROVIDER_FALLBACK=
EMAIL_SEND_TIMEOUT_SEC=8
EMAIL_FROM=no-reply@time-tree.local
EMAIL_DIGEST_ENABLED=true
EMAIL_DIGEST_DAILY_INTERVAL_HOURS=24
EMAIL_DIGEST_WEEKLY_INTERVAL_HOURS=168
RESEND_API_KEY=
RESEND_API_ENDPOINT=https://api.resend.com/emails
SENDGRID_API_KEY=
SENDGRID_API_ENDPOINT=https://api.sendgrid.com/v3/mail/send
DEFAULT_LOCALE=zh-TW

# ── Worker (BE-P2-08) ──────────────────────────────────────
WORKER_POLL_INTERVAL_SEC=1
WORKER_BATCH_SIZE=50
WORKER_HTTP_PORT=8091
INVITATION_REMINDER_ENABLED=true
INVITATION_REMINDER_INTERVAL_MIN=60
INVITATION_REMINDER_LOOKAHEAD_HOURS=24

# ── Web Runtime (docker compose only) ───────────────────────
WEB_PORT=80
